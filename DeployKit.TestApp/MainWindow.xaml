<Window x:Class="DeployKit.TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TestApp" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="DeployKit TestApp" FontSize="22" FontWeight="700"
                       HorizontalAlignment="Center" Foreground="#1A1B2E"/>
            <TextBlock x:Name="VersionText" FontSize="16"
                       HorizontalAlignment="Center" Foreground="#6B7280"
                       Margin="0,8,0,24"/>
            <Button x:Name="CheckBtn" Content="🔍  فحص التحديثات"
                    HorizontalAlignment="Center"
                    Padding="24,10" FontSize="14"
                    Background="#4F46E5" Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnCheckClick"/>
            <TextBlock x:Name="StatusText" FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="#9CA3AF" Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</Window>
