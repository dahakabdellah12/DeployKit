<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Content -->
    <SolidColorBrush x:Key="ContentBg" Color="#121220"/>
    <SolidColorBrush x:Key="CardBg" Color="#1E1E34"/>
    <SolidColorBrush x:Key="CardBorder" Color="#2D2E4A"/>
    <SolidColorBrush x:Key="CardShadow" Color="#4A000000"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Primary" Color="#818CF8"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryLight" Color="#1E1B4B"/>
    <SolidColorBrush x:Key="Success" Color="#34D399"/>
    <SolidColorBrush x:Key="SuccessLight" Color="#064E3B"/>
    <SolidColorBrush x:Key="Warning" Color="#FBBF24"/>
    <SolidColorBrush x:Key="WarningLight" Color="#451A03"/>
    <SolidColorBrush x:Key="Danger" Color="#F87171"/>
    <SolidColorBrush x:Key="DangerLight" Color="#450A0A"/>
    <SolidColorBrush x:Key="Info" Color="#60A5FA"/>
    <SolidColorBrush x:Key="InfoLight" Color="#1E3A5F"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBg" Color="#252540"/>
    <SolidColorBrush x:Key="InputBorder" Color="#3D3E5C"/>
    <SolidColorBrush x:Key="InputFocusBorder" Color="#818CF8"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="ProgressBg" Color="#2D2E4A"/>
    <SolidColorBrush x:Key="ProgressFill" Color="#818CF8"/>

    <!-- Severity colors -->
    <SolidColorBrush x:Key="AddedColor" Color="#34D399"/>
    <SolidColorBrush x:Key="ModifiedColor" Color="#FBBF24"/>
    <SolidColorBrush x:Key="DeletedColor" Color="#F87171"/>
    <SolidColorBrush x:Key="UnchangedColor" Color="#64748B"/>

    <!-- Header bar -->
    <SolidColorBrush x:Key="HeaderBg" Color="#1A1B2F"/>
    <SolidColorBrush x:Key="HeaderBorder" Color="#2D2E4A"/>
</ResourceDictionary>
