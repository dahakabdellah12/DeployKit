<Window x:Class="DeployKit.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeployKit.Gui.ViewModels"
        xmlns:conv="clr-namespace:DeployKit.Gui.Converters"
        Title="DeployKit" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
        Background="{DynamicResource ContentBg}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolInvertConverter x:Key="BoolInvert"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmpty"/>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SidebarItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SidebarItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                CornerRadius="10" Padding="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryLight}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="DeployKit"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                    <Setter Property="Title" Value="DeployKit - الرئيسية"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                    <Setter Property="Title" Value="DeployKit - بناء تحديث"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                    <Setter Property="Title" Value="DeployKit - تطبيق تحديث"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                    <Setter Property="Title" Value="DeployKit - الإعدادات"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                CornerRadius="0">
            <Grid Margin="0,8,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Row="0" Text="DK" FontSize="22" FontWeight="800"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,12,0,8"/>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowHomeCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5"
                                    HorizontalAlignment="Left" Margin="0,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowBuildCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="🔨" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowApplyCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowSettingsCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Bottom -->
                <StackPanel Grid.Row="2">
                    <Border Height="1" Background="{StaticResource SidebarDivider}" Margin="8,0,8,8"/>
                    <Button Style="{StaticResource SidebarButton}" Height="40"
                            Command="{Binding ToggleThemeCommand}">
                        <TextBlock Text="{Binding ThemeIcon}" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <TextBlock Text="v1" FontSize="9"
                               Foreground="{StaticResource SidebarText}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CONTENT ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                    BorderBrush="{DynamicResource HeaderBorder}" BorderThickness="0,0,0,1"
                    Padding="24,14">
                <TextBlock FontSize="16" FontWeight="600"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="الرئيسية"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                    <Setter Property="Text" Value="بناء تحديث"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                    <Setter Property="Text" Value="تطبيق تحديث"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                    <Setter Property="Text" Value="الإعدادات"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Content area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource ContentBg}"
                          Padding="24"
                          AllowDrop="True"
                          DragOver="Content_DragOver"
                          Drop="Content_Drop">
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <!-- ===== HOME PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                            <StackPanel>
                                <TextBlock Text="مرحباً بك في DeployKit" FontSize="28" FontWeight="700"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="أداة إنشاء وتطبيق حزم التحديث التفاضلي (Delta Updates)"
                                           FontSize="15" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,6,0,28"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Style="{StaticResource CardButton}"
                                            Command="{Binding ShowBuildCommand}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="56" Height="56" CornerRadius="14"
                                                    Background="{DynamicResource PrimaryLight}"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="🔨" FontSize="28"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="بناء تحديث" FontSize="17" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       HorizontalAlignment="Center" Margin="0,14,0,4"/>
                                            <TextBlock Text="قارن إصدارين وأنشئ حزمة .zip"
                                                       FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2" Style="{StaticResource CardButton}"
                                            Command="{Binding ShowApplyCommand}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="56" Height="56" CornerRadius="14"
                                                    Background="{DynamicResource InfoLight}"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="📦" FontSize="28"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="تطبيق تحديث" FontSize="17" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       HorizontalAlignment="Center" Margin="0,14,0,4"/>
                                            <TextBlock Text="طبق حزمة تحديث على مجلد التثبيت"
                                                       FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <StackPanel Margin="0,32,0,0"
                                            Visibility="{Binding HasRecentProjects, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="أحدث المشاريع" FontSize="16" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <Button Grid.Column="1" Content="مسح الكل"
                                                Command="{Binding ClearRecentCommand}"
                                                FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding RecentProjects}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                                Background="{DynamicResource PrimaryLight}"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Name, StringFormat={}{0:0}}" FontSize="16"
                                                                       Foreground="{DynamicResource Primary}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Name}" FontWeight="600"
                                                                       Foreground="{DynamicResource TextPrimary}"/>
                                                            <TextBlock FontSize="12" Margin="0,2,0,0"
                                                                       Foreground="{DynamicResource TextSecondary}">
                                                                <Run Text="{Binding FromVersion}"/>
                                                                <Run Text=" → "/>
                                                                <Run Text="{Binding ToVersion}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" FontSize="12"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{Binding LastUsed, StringFormat={}{0:HH:mm}}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== BUILD PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:BuildViewModel}">
                            <StackPanel>
                                <TextBlock Text="بناء حزمة تحديث" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="قارن بين مجلدين وأنشئ حزمة .zip تحتوي على التغييرات فقط"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <Border Style="{StaticResource Card}" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="المجلد القديم (Source)" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding OldDir}" IsReadOnly="True"/>
                                                <Button Grid.Column="1" Content="📂"
                                                        Command="{Binding SelectOldDirCommand}"
                                                        Background="{DynamicResource PrimaryLight}"
                                                        BorderThickness="0" Width="36" Height="36"
                                                        Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                        Foreground="{DynamicResource Primary}"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                            <TextBlock Text="المجلد الجديد (Target)" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding NewDir}" IsReadOnly="True"/>
                                                <Button Grid.Column="1" Content="📂"
                                                        Command="{Binding SelectNewDirCommand}"
                                                        Background="{DynamicResource PrimaryLight}"
                                                        BorderThickness="0" Width="36" Height="36"
                                                        Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                        Foreground="{DynamicResource Primary}"/>
                                            </Grid>
                                        </StackPanel>

                                        <Button Grid.Row="2" Content="🔍  مقارنة المجلدين"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding CompareCommand}"
                                                IsEnabled="{Binding IsComparing, Converter={StaticResource BoolInvert}}"
                                                Margin="0,20,0,0" HorizontalAlignment="Center"/>

                                        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="16"
                                                Margin="0,16,0,0"
                                                Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <ProgressBar IsIndeterminate="True" Height="4"
                                                             Background="{DynamicResource ProgressBg}" BorderThickness="0">
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar">
                                                            <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>
                                                <TextBlock Text="جاري المقارنة..." FontSize="13"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource Card}" Padding="20"
                                        Margin="0,16,0,0"
                                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📊  نتيجة المقارنة" FontWeight="600" FontSize="15"
                                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="➕" FontSize="28" FontWeight="700"
                                                           Foreground="{DynamicResource AddedColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="جديد" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="📝" FontSize="28" FontWeight="700"
                                                           Foreground="{DynamicResource ModifiedColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="معدل" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="🗑️" FontSize="28" FontWeight="700"
                                                           Foreground="{DynamicResource DeletedColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="محذوف" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Changes}" MaxHeight="200">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,4" Margin="0,2" CornerRadius="6" Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="80"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Type}"
                                                                       FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                                       FontSize="13" Foreground="{Binding Color}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Size}"
                                                                       FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                                       HorizontalAlignment="Right"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Separator Margin="0,14"/>

                                        <Border Background="{DynamicResource SuccessLight}" CornerRadius="8" Padding="12"
                                                Margin="0,0,0,14"
                                                Visibility="{Binding SavingsInfo, Converter={StaticResource StringNotEmpty}}">
                                            <TextBlock Text="{Binding SavingsInfo}" FontSize="13"
                                                       Foreground="{DynamicResource Success}"/>
                                        </Border>

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,12,0">
                                                <TextBlock Text="الإصدار القديم" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding SourceVersion}" Width="90"
                                                         HorizontalAlignment="Right"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="→" FontSize="20"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Left" Margin="12,0,0,0">
                                                <TextBlock Text="الإصدار الجديد" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding TargetVersion}" Width="90"/>
                                            </StackPanel>
                                        </Grid>

                                        <ProgressBar Value="{Binding Progress}" Maximum="100"
                                                     Height="6" Margin="0,0,0,14"
                                                     Background="{DynamicResource ProgressBg}" BorderThickness="0"
                                                     Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVis}}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>

                                        <Button Content="💾  تصدير حزمة التحديث"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding BuildPackageCommand}"
                                                IsEnabled="{Binding HasResult}"
                                                HorizontalAlignment="Center"/>

                                        <Button Content="☁️  رفع إلى السحابة"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding UploadToCloudCommand}"
                                                IsEnabled="{Binding HasResult}"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== APPLY PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:ApplyViewModel}">
                            <StackPanel>
                                <TextBlock Text="تطبيق تحديث" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="طبق حزمة تحديث .zip على مجلد التثبيت"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <Border Style="{StaticResource Card}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="ملف التحديث" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PackagePath}" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="📂"
                                                    Command="{Binding SelectPackageCommand}"
                                                    Background="{DynamicResource PrimaryLight}"
                                                    BorderThickness="0" Width="36" Height="36"
                                                    Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                    Foreground="{DynamicResource Primary}"/>
                                        </Grid>

                                        <TextBlock Text="مجلد التثبيت" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,16,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding TargetDir}" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="📂"
                                                    Command="{Binding SelectTargetCommand}"
                                                    Background="{DynamicResource PrimaryLight}"
                                                    BorderThickness="0" Width="36" Height="36"
                                                    Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                    Foreground="{DynamicResource Primary}"/>
                                        </Grid>

                                        <Border Background="{DynamicResource InfoLight}" CornerRadius="8" Padding="14"
                                                Margin="0,16,0,0"
                                                Visibility="{Binding HasPackageInfo, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding PackageInfo}" FontSize="13"
                                                       Foreground="{DynamicResource Info}" LineHeight="22"/>
                                        </Border>

                                        <ProgressBar Value="{Binding Progress}" Maximum="100"
                                                     Height="6" Margin="0,16,0,0"
                                                     Background="{DynamicResource ProgressBg}" BorderThickness="0"
                                                     Visibility="{Binding IsApplying, Converter={StaticResource BoolToVis}}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>

                                        <Button Content="▶️  بدء التحديث"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding ApplyCommand}"
                                                IsEnabled="{Binding HasPackageInfo}"
                                                Margin="0,16,0,0" HorizontalAlignment="Center"/>

                                        <TextBlock Text="{Binding StatusMessage}"
                                                   FontSize="14" Margin="0,12,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimary}"/>

                                        <Border Background="{DynamicResource WarningLight}" CornerRadius="8" Padding="12"
                                                Margin="0,12,0,0"
                                                Visibility="{Binding BackupPath, Converter={StaticResource StringNotEmpty}}">
                                            <TextBlock FontSize="12" Foreground="{DynamicResource Warning}">
                                                <Run Text="📂  النسخة الاحتياطية في:"/>
                                                <Run Text="{Binding BackupPath}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== SETTINGS PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="الإعدادات السحابية" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="سجل تطبيقك واحصل على API Key لربطه مع السحابة"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <Border Style="{StaticResource Card}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="اسم التطبيق" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding AppName, Mode=TwoWay}"
                                                     Margin="0,0,8,0"/>
                                            <Button Grid.Column="1" Content="🆕  تسجيل"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding RegisterCommand}"/>
                                        </Grid>

                                        <TextBlock Text="رابط السحابة" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,16,0,6"/>
                                        <TextBox Text="{Binding CloudUrl, Mode=TwoWay}"/>

                                        <Border Background="{DynamicResource InfoLight}" CornerRadius="8" Padding="14"
                                                Margin="0,16,0,0">
                                            <StackPanel>
                                                <TextBlock Text="🔑  API Key الخاص بك" FontWeight="600"
                                                           Foreground="{DynamicResource Info}" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding ApiKey}" IsReadOnly="True"
                                                             FontFamily="Consolas" FontSize="13"/>
                                                    <Button Grid.Column="1" Content="📋  نسخ"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Command="{Binding CopyKeyCommand}"
                                                            Margin="8,0,0,0"
                                                            Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="{Binding StatusMessage}"
                                                   FontSize="13" Margin="0,12,0,0"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
