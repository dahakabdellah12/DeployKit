<Window x:Class="DeployKit.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeployKit.Gui.ViewModels"
        xmlns:conv="clr-namespace:DeployKit.Gui.Converters"
        xmlns:helpers="clr-namespace:DeployKit.Gui.Helpers"
        Title="DeployKit - منشئ التحديثات" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
        Background="{DynamicResource ContentBg}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolInvertConverter x:Key="BoolInvert"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmpty"/>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SidebarItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SidebarItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryLight}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource Success}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource InputFocusBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Title" Value="DeployKit - منشئ التحديثات"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                    <Setter Property="Title" Value="DeployKit - الإصدارات"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                    <Setter Property="Title" Value="DeployKit - إصدار جديد"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                    <Setter Property="Title" Value="DeployKit - الإعدادات"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" CornerRadius="0">
            <Grid Margin="0,8,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DK" FontSize="22" FontWeight="800"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,8"/>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowHomeCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowBuildCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="🚀" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowUploadCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="📤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowSettingsCommand}">
                        <Grid>
                            <Border Width="3" Height="20" CornerRadius="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                <Setter Property="Background" Value="{StaticResource SidebarAccent}"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarTextSelected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Border Height="1" Background="{StaticResource SidebarDivider}" Margin="8,0,8,8"/>
                    <Button Style="{StaticResource SidebarButton}" Height="40"
                            Command="{Binding ToggleThemeCommand}">
                        <TextBlock Text="{Binding ThemeIcon}" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <TextBlock Text="v1" FontSize="9"
                               Foreground="{StaticResource SidebarText}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CONTENT ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBg}"
                    BorderBrush="{DynamicResource HeaderBorder}" BorderThickness="0,0,0,1"
                    Padding="24,14">
                <TextBlock FontSize="16" FontWeight="600"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="الإصدارات"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                    <Setter Property="Text" Value="إصدار جديد"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                    <Setter Property="Text" Value="رفع إلى GitHub"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                    <Setter Property="Text" Value="الإعدادات"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Content area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource ContentBg}"
                          Padding="24">
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <!-- ===== HOME / RELEASES PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                            <StackPanel>
                                <TextBlock Text="الإصدارات" FontSize="28" FontWeight="700"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="سجل الإصدارات والتحديثات التي أنشأتها"
                                           FontSize="14" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,4,0,24"/>

                                <!-- Stats -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding TotalReleases}" FontSize="28" FontWeight="700"
                                                       Foreground="{DynamicResource Primary}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="إصدار" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding TotalSize}" FontSize="28" FontWeight="700"
                                                       Foreground="{DynamicResource Success}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="الحجم الإجمالي" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding CloudCount}" FontSize="28" FontWeight="700"
                                                       Foreground="{DynamicResource Warning}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="في السحابة" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Button Content="🚀  إنشاء إصدار جديد"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ShowBuildCommand}"
                                        HorizontalAlignment="Center" Margin="0,0,0,24"/>

                                <!-- Releases list -->
                                <StackPanel Visibility="{Binding HasReleases, Converter={StaticResource BoolToVis}}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="الإصدارات السابقة" FontSize="15" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="مسح الكل"
                                                Command="{Binding ClearHistoryCommand}"
                                                FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Releases}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type helpers:ReleaseRecord}">
                                                <Border Style="{StaticResource CardStyle}"
                                                        Margin="0,0,0,8" Padding="16"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="ReleaseItem_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock FontWeight="600" Foreground="{DynamicResource TextPrimary}">
                                                                <Run Text="{Binding AppName}"/>
                                                                <Run Text="v"/>
                                                                <Run Text="{Binding FromVersion}"/>
                                                                <Run Text="→"/>
                                                                <Run Text="v"/>
                                                                <Run Text="{Binding ToVersion}"/>
                                                            </TextBlock>
                                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                                                       Margin="0,2,0,0"
                                                                       Text="{Binding CreatedAt}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="☁️" FontSize="14" Margin="0,0,4,0"
                                                                       Visibility="{Binding IsRegisteredInCloud, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}">
                                                            <Run Text="v"/><Run Text="{Binding ToVersion}"/></TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Border Style="{StaticResource CardStyle}" Padding="24"
                                        Visibility="{Binding HasReleases, Converter={StaticResource BoolInvert}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                                        <TextBlock Text="لا توجد إصدارات بعد" FontSize="16"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                        <TextBlock Text="أنشئ أول إصدار لتطبيقك الآن!"
                                                   FontSize="13" Foreground="{DynamicResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== BUILD / NEW RELEASE PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:BuildViewModel}">
                            <StackPanel>
                                <TextBlock Text="إنشاء إصدار جديد" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="اختر مجلد التطبيق الجديد وأنشئ حزمة تحديث كاملة"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <!-- App Info -->
                                <Border Style="{StaticResource CardStyle}" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- New dir -->
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="مجلد التطبيق الجديد" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding NewDir}" IsReadOnly="True"/>
                                                <Button Grid.Column="1" Content="📂"
                                                        Command="{Binding SelectNewDirCommand}"
                                                        Background="{DynamicResource PrimaryLight}"
                                                        BorderThickness="0" Width="36" Height="36"
                                                        Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                        Foreground="{DynamicResource Primary}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Version + App Name -->
                                        <Grid Grid.Row="1" Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="رقم الإصدار" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Version}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="اسم التطبيق" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding AppName}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Release Notes -->
                                        <StackPanel Grid.Row="2" Margin="0,14,0,0">
                                            <TextBlock Text="ملاحظات الإصدار (Release Notes)" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding ReleaseNotes, Mode=TwoWay}"
                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="80" FontSize="13"/>
                                            <CheckBox IsChecked="{Binding IsMandatory}" Margin="0,10,0,0"
                                                       Foreground="{DynamicResource TextPrimary}">
                                                تحديث إجباري (Mandatory)
                                            </CheckBox>
                                            <CheckBox IsChecked="{Binding UploadToGitHub}" Margin="0,8,0,0"
                                                       Foreground="{DynamicResource TextPrimary}">
                                                🐙 رفع إلى GitHub Releases
                                            </CheckBox>
                                        </StackPanel>

                                        <!-- Build progress -->
                                        <ProgressBar Grid.Row="3" Value="{Binding Progress}" Maximum="100"
                                                     Height="6" Margin="0,16,0,0"
                                                     Background="{DynamicResource ProgressBg}" BorderThickness="0"
                                                     Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVis}}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </Grid>
                                </Border>

                                <!-- Action buttons -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <Button Content="🚀  بناء ورفع إلى GitHub"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding BuildPackageCommand}"
                                            IsEnabled="{Binding CanBuild}"
                                            HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Download URL -->
                                <Border Style="{StaticResource CardStyle}" Padding="16"
                                        Margin="0,14,0,0"
                                        Visibility="{Binding HasDownloadUrl, Converter={StaticResource BoolToVis}}"
                                        Background="{DynamicResource InfoLight}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🔗  رابط التحميل" FontWeight="600" FontSize="13"
                                                       Foreground="{DynamicResource Info}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding DownloadUrl}" FontSize="11"
                                                       Foreground="{DynamicResource Info}" TextWrapping="Wrap"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="📋  نسخ"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding CopyDownloadUrlCommand}"
                                                Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Working overlay -->
                                <Border Style="{StaticResource CardStyle}" Padding="20"
                                        Margin="0,14,0,0"
                                        Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <ProgressBar IsIndeterminate="True" Height="4"
                                                     Background="{DynamicResource ProgressBg}" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Status message -->
                                <Border Padding="14" Margin="0,10,0,0"
                                        Background="{DynamicResource CardBg}"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== UPLOAD PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:UploadViewModel}">
                            <StackPanel>
                                <TextBlock Text="رفع حزمة إلى GitHub" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="اختر ملف ZIP موجود وارفعه إلى GitHub Releases"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <!-- File picker -->
                                <Border Style="{StaticResource CardStyle}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="ملف التحديث (ZIP)" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding FilePath}" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="📂"
                                                    Command="{Binding SelectFileCommand}"
                                                    Background="{DynamicResource PrimaryLight}"
                                                    BorderThickness="0" Width="36" Height="36"
                                                    Margin="8,0,0,0" Cursor="Hand" FontSize="16"
                                                    Foreground="{DynamicResource Primary}"/>
                                        </Grid>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="رقم الإصدار" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Version}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="اسم التطبيق" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding AppName}"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="ملاحظات الإصدار (Release Notes)" FontWeight="600"
                                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding ReleaseNotes, Mode=TwoWay}"
                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="80" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Upload button -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <Button Content="🐙  رفع إلى GitHub Releases"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding UploadCommand}"
                                            IsEnabled="{Binding CanUpload}"
                                            HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Working overlay -->
                                <Border Style="{StaticResource CardStyle}" Padding="20"
                                        Margin="0,14,0,0"
                                        Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <ProgressBar IsIndeterminate="True" Height="4"
                                                     Background="{DynamicResource ProgressBg}" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource ProgressFill}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Status -->
                                <Border Padding="14" Margin="0,10,0,0"
                                        Background="{DynamicResource CardBg}"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Download URL -->
                                <Border Style="{StaticResource CardStyle}" Padding="16"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding HasDownloadUrl, Converter={StaticResource BoolToVis}}"
                                        Background="{DynamicResource InfoLight}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🔗  رابط التحميل" FontWeight="600" FontSize="13"
                                                       Foreground="{DynamicResource Info}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding DownloadUrl}" FontSize="11"
                                                       Foreground="{DynamicResource Info}" TextWrapping="Wrap"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="📋  نسخ"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding CopyDownloadUrlCommand}"
                                                Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ===== SETTINGS PAGE ===== -->
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="الإعدادات" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="إعدادات السحابة و GitHub"
                                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,0,20"/>

                                <!-- Cloud settings -->
                                <Border Style="{StaticResource CardStyle}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="☁️  السحابة (DeployKit API)" FontSize="15" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                                        <TextBlock Text="اسم التطبيق" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding AppName, Mode=TwoWay}"/>

                                        <TextBlock Text="رابط السحابة" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,14,0,6"/>
                                        <TextBox Text="{Binding CloudUrl, Mode=TwoWay}"/>

                                        <Border Background="{DynamicResource InfoLight}" CornerRadius="8" Padding="14"
                                                Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="🔑  API Key" FontWeight="600"
                                                           Foreground="{DynamicResource Info}" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding ApiKey, Mode=TwoWay}"
                                                             FontFamily="Consolas" FontSize="12"/>
                                                    <Button Grid.Column="1" Content="📋"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Command="{Binding CopyKeyCommand}"
                                                            Margin="8,0,0,0"
                                                            Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                                <TextBlock Text="💡 سجل التطبيق في Dashboard → أنشئ API Key → انسخه والصقه هنا"
                                                           FontSize="11" Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,6,0,0"/>
                                                <Button Content="🌐  فتح Dashboard"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Command="{Binding OpenDashboardCommand}"
                                                        HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- GitHub settings -->
                                <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="🐙  GitHub" FontSize="15" FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="GitHub User" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding GitHubUser, Mode=TwoWay}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="GitHub Repo" FontWeight="600"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding GitHubRepo, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="GitHub Token (classic PAT with repo scope)"
                                                   FontWeight="600"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,14,0,6"/>
                                        <TextBox Text="{Binding GitHubToken, Mode=TwoWay}"
                                                 FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap">
                                        ⚠️ هذا الحقل ضروري لرفع الملفات إلى GitHub Releases.
                                        أنشئ Token من:
                                        <Hyperlink NavigateUri="https://github.com/settings/tokens" RequestNavigate="Hyperlink_RequestNavigate">
                                            github.com/settings/tokens
                                        </Hyperlink>
                                        (New Token → repo scope → copy والصقه هنا)</TextBlock>

                                        <Button Content="💾  حفظ الإعدادات"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding SaveSettingsCommand}"
                                                HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="13" Margin="0,12,0,0"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
